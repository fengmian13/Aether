<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.anther.mappers.UserGroupMapper">

	<!--实体映射-->
	<resultMap id="base_result_map" type="com.anther.entity.po.UserGroup">
		<!---->
		<result column="user_id" property="userId"  />
		<!---->
		<result column="group_id" property="groupId"  />
		<!---->
		<result column="role_id" property="roleId"  />
	</resultMap>


	<!-- 通用查询结果列-->
	<sql id="base_column_list">
		 user_id,group_id,role_id
	</sql>

	<sql id="base_condition_filed">
		<if test="query.userId != null and query.userId!=''">
			 and  user_id = #{query.userId}
		</if>
		<if test="query.groupId != null and query.groupId!=''">
			 and  group_id = #{query.groupId}
		</if>
		<if test="query.roleId != null and query.roleId!=''">
			 and  role_id = #{query.roleId}
		</if>
	</sql>

	<!-- 通用查询条件列-->
	<sql id="query_condition">
		<where>
			<include refid="base_condition_filed" />
			<if test="query.userIdFuzzy!= null  and query.userIdFuzzy!=''">
				 and  user_id like concat('%', #{query.userIdFuzzy}, '%')
			</if>
			<if test="query.groupIdFuzzy!= null  and query.groupIdFuzzy!=''">
				 and  group_id like concat('%', #{query.groupIdFuzzy}, '%')
			</if>
			<if test="query.roleIdFuzzy!= null  and query.roleIdFuzzy!=''">
				 and  role_id like concat('%', #{query.roleIdFuzzy}, '%')
			</if>
		</where>
	</sql>

	<!-- 查询集合-->
	<select id="selectList" resultMap="base_result_map" >
		 SELECT <include refid="base_column_list" /> FROM user_group <include refid="query_condition" />
		 <if test="query.orderBy!=null">
			 order by ${query.orderBy}
		 </if>
		 <if test="query.simplePage!=null">
			 limit #{query.simplePage.start},#{query.simplePage.end}
		 </if>
	</select>

	<select id="selectListByQuery"
			parameterType="com.anther.entity.query.UserGroupQuery"
			resultType="com.anther.entity.dto.UserGroupContactDto">

		SELECT
		ug.group_id   AS groupId,
		gi.group_name AS groupName,
		ug.role_id    AS groupRole
		FROM user_group ug
		INNER JOIN group_info gi
		ON ug.group_id = gi.group_id

		<where>
			<if test="userId != null and userId != ''">
				ug.user_id = #{userId}
			</if>
			<if test="roleId != null and roleId != ''">
				and ug.role_id != #{roleId}
			</if>
		</where>
	</select>


	<!-- 查询数量-->
	<select id="selectCount" resultType="java.lang.Integer" >
		 SELECT count(1) FROM user_group <include refid="query_condition" />
	</select>

	<!-- 插入 （匹配有值的字段）-->
	<insert id="insert" parameterType="com.anther.entity.po.UserGroup">
		 INSERT INTO user_group
		 <trim prefix="(" suffix=")" suffixOverrides="," >
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.groupId != null">
				 group_id,
			</if>
			<if test="bean.roleId != null">
				 role_id,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides="," >
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.groupId!=null">
				 #{bean.groupId},
			</if>
			<if test="bean.roleId!=null">
				 #{bean.roleId},
			</if>
		 </trim>
	</insert>

	<!-- 插入或者更新 （匹配有值的字段）-->
	<insert id="insertOrUpdate" parameterType="com.anther.entity.po.UserGroup">
		 INSERT INTO user_group
		 <trim prefix="(" suffix=")" suffixOverrides=",">
			<if test="bean.userId != null">
				 user_id,
			</if>
			<if test="bean.groupId != null">
				 group_id,
			</if>
			<if test="bean.roleId != null">
				 role_id,
			</if>
		 </trim>
		 <trim prefix="values (" suffix=")" suffixOverrides=",">
			<if test="bean.userId!=null">
				 #{bean.userId},
			</if>
			<if test="bean.groupId!=null">
				 #{bean.groupId},
			</if>
			<if test="bean.roleId!=null">
				 #{bean.roleId},
			</if>
		 </trim>
		 on DUPLICATE key update 
		 <trim prefix="" suffix="" suffixOverrides=",">
			<if test="bean.userId!=null">
				 user_id = VALUES(user_id),
			</if>
			<if test="bean.groupId!=null">
				 group_id = VALUES(group_id),
			</if>
			<if test="bean.roleId!=null">
				 role_id = VALUES(role_id),
			</if>
		 </trim>
	</insert>

	<!-- 添加 （批量插入）-->
	<insert id="insertBatch" parameterType="com.anther.entity.po.UserGroup">
		 INSERT INTO user_group(
			 user_id,
			 group_id,
			 role_id
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.userId},
				 #{item.groupId},
				 #{item.roleId}
			 )
		 </foreach>
	</insert>

	<!-- 批量新增修改 （批量插入）-->
	<insert id="insertOrUpdateBatch" parameterType="com.anther.entity.po.UserGroup">
		 INSERT INTO user_group(
			 user_id,
			 group_id,
			 role_id
		 )values
		 <foreach collection="list" item="item" separator=",">
			 (
				 #{item.userId},
				 #{item.groupId},
				 #{item.roleId}
			 )
		 </foreach>
			on DUPLICATE key update 
			user_id = VALUES(user_id),
			group_id = VALUES(group_id),
			role_id = VALUES(role_id)
	</insert>

	<!--多条件修改-->
	<update id="updateByParam" parameterType="com.anther.entity.query.UserGroupQuery">
		 UPDATE user_group
 		 <set> 
			<if test="bean.userId != null">
				 user_id = #{bean.userId},
			</if>
			<if test="bean.groupId != null">
				 group_id = #{bean.groupId},
			</if>
			<if test="bean.roleId != null">
				 role_id = #{bean.roleId},
			</if>
 		 </set>
 		 <include refid="query_condition" />
	</update>

	<!--多条件删除-->
	<delete id="deleteByParam">
		 delete from user_group
 		 <include refid="query_condition" />
	</delete>

</mapper>